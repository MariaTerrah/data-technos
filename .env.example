# ============================================================
# Tech Watch — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# --- Gemini API (for summarization) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Brave Search API (for article search) ---
BRAVE_API_KEY=your_brave_api_key_here

# --- Supabase (for article storage) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_anon_public_key_here

# --- Gmail MCP ---
GMAIL_CLIENT_ID=your_gmail_oauth_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_oauth_refresh_token_here
GMAIL_SENDER_EMAIL=your_gmail_address@gmail.com
DIGEST_RECIPIENTS=your_gmail_address@gmail.com
